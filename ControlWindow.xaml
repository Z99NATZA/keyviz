<Window x:Class="KeyViz.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyViz controls"
        Width="188"
        Height="68"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{StaticResource Theme.AppSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Theme.AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Theme.AppTextBrush}" />
            <Setter Property="FontFamily" Value="Inter, Noto Sans Thai, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Theme.AppTextBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionHoverBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource Theme.ActionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Padding="8"
            Background="{StaticResource Theme.AppPanelBrush}"
            BorderBrush="{StaticResource Theme.AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Color="{StaticResource Theme.ShadowColor}"
                              Direction="270"
                              Opacity="0.55"
                              ShadowDepth="4" />
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button x:Name="ShowButton"
                    Width="76"
                    Height="38"
                    Margin="0,0,4,0"
                    Click="ShowButtonOnClick"
                    Content="Show" />
            <Button x:Name="HideButton"
                    Width="76"
                    Height="38"
                    Margin="4,0,0,0"
                    Click="HideButtonOnClick"
                    Content="Hide" />
        </StackPanel>
    </Border>
</Window>
