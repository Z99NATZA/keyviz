<Window x:Class="KeyViz.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyViz controls"
        Width="120"
        Height="50"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="{StaticResource Theme.AppSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Theme.AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Theme.AppTextBrush}" />
            <Setter Property="FontFamily" Value="Inter, Noto Sans Thai, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Theme.AppTextBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionHoverBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource Theme.ActionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RepeatButton">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="{StaticResource Theme.AppSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Theme.AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Theme.AppTextBrush}" />
            <Setter Property="FontFamily" Value="Inter, Noto Sans Thai, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Theme.AppTextBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionHoverBrush}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource Theme.ActionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource Theme.ActionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Theme.MutedTextBrush}" />
            <Setter Property="FontFamily" Value="Inter, Noto Sans Thai, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>
    <Grid>
        <Border x:Name="PropertiesPanel"
                Width="260"
                Height="196"
                Margin="4,0,0,0"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{StaticResource Theme.AppPanelBrush}"
                BorderBrush="{StaticResource Theme.AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Color="{StaticResource Theme.ShadowColor}"
                                  Direction="270"
                                  Opacity="0.55"
                                  ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PropertyLabelStyle}"
                               Text="Show keystrokes" />
                    <Button x:Name="OverlayButton"
                            Grid.Column="1"
                            Width="64"
                            Height="30"
                            HorizontalAlignment="Right"
                            Click="OverlayButtonOnClick"
                            Content="On" />
                </Grid>
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PropertyLabelStyle}"
                               Text="Keyviz button" />
                    <Button x:Name="ControlsButton"
                            Grid.Column="1"
                            Width="64"
                            Height="30"
                            HorizontalAlignment="Right"
                            Click="ControlsButtonOnClick"
                            Content="On" />
                </Grid>
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PropertyLabelStyle}"
                               Text="History limit" />
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <RepeatButton Width="30"
                                      Height="30"
                                      Padding="0"
                                      Delay="400"
                                      Interval="80"
                                      Tag="-1"
                                      PreviewMouseLeftButtonDown="HistoryButtonOnPreviewMouseLeftButtonDown"
                                      Click="HistoryButtonOnClick"
                                      Content="−" />
                        <TextBlock x:Name="HistoryLengthText"
                                   Width="48"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Theme.AppTextBrush}"
                                   FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <RepeatButton Width="30"
                                      Height="30"
                                      Padding="0"
                                      Delay="400"
                                      Interval="80"
                                      Tag="1"
                                      PreviewMouseLeftButtonDown="HistoryButtonOnPreviewMouseLeftButtonDown"
                                      Click="HistoryButtonOnClick"
                                      Content="+" />
                    </StackPanel>
                </Grid>
                <Grid Height="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PropertyLabelStyle}"
                               Text="Position" />
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button x:Name="LeftPositionButton"
                                Width="52"
                                Height="30"
                                Margin="0,0,3,0"
                                Padding="0"
                                Tag="left"
                                Click="PositionButtonOnClick"
                                Content="Left" />
                        <Button x:Name="CenterPositionButton"
                                Width="52"
                                Height="30"
                                Margin="0,0,3,0"
                                Padding="0"
                                Tag="center"
                                Click="PositionButtonOnClick"
                                Content="Center" />
                        <Button x:Name="RightPositionButton"
                                Width="52"
                                Height="30"
                                Padding="0"
                                Tag="right"
                                Click="PositionButtonOnClick"
                                Content="Right" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Button x:Name="KeyVizButton"
                Width="112"
                Height="42"
                Margin="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Click="KeyVizButtonOnClick"
                Content="Keyviz" />
    </Grid>
</Window>
