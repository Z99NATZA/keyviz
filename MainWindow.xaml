<Window x:Class="KeyViz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyViz"
        Height="220"
        SizeToContent="Width"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Focusable="False">
    <Grid IsHitTestVisible="False">
        <Border x:Name="DisplayPanel"
                Padding="20,14"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="{StaticResource Theme.AppPanelBrush}"
                BorderBrush="{StaticResource Theme.AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Opacity="0">
            <ScrollViewer x:Name="TokenScroller"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TokenItemsControl"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Margin" Value="1,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="CornerRadius" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSpecial}" Value="True">
                                                <Setter Property="Margin" Value="5,0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Value}"
                                           TextWrapping="NoWrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource Theme.AppTextBrush}" />
                                            <Setter Property="FontFamily"
                                                    Value="JetBrains Mono, Cascadia Mono, Consolas, Leelawadee UI, Tahoma, Segoe UI" />
                                            <Setter Property="FontSize" Value="26" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpecial}" Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource Theme.SpecialTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
